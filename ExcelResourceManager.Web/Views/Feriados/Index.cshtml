@model IEnumerable<ExcelResourceManager.Web.Models.FeriadoViewModel>

@{
    ViewData["Title"] = "Feriados";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2><i class="bi bi-calendar-event me-2"></i>Feriados</h2>
        <div class="d-flex gap-2">
            <a asp-action="ExportarExcel" class="btn btn-outline-success">
                <i class="bi bi-file-earmark-excel me-1"></i>Exportar Excel
            </a>
            <a asp-action="ImportarExcel" class="btn btn-outline-primary">
                <i class="bi bi-file-earmark-arrow-up me-1"></i>Importar Excel
            </a>
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-circle me-1"></i>Nuevo Feriado
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-circle me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card mb-3">
        <div class="card-body">
            <form method="get" class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label">Ubicación</label>
                    <select name="ubicacionId" asp-items="ViewBag.Ubicaciones" class="form-select">
                        <option value="">— Todas las ubicaciones —</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Año</label>
                    <select name="año" class="form-select">
                        <option value="">— Todos los años —</option>
                        @foreach (var item in (IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>)ViewBag.AñosDisponibles)
                        {
                            <option value="@item.Value" selected="@item.Selected">@item.Text</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-outline-primary w-100">
                        <i class="bi bi-funnel me-1"></i>Filtrar
                    </button>
                </div>
                <div class="col-md-2">
                    <a asp-action="Index" class="btn btn-outline-secondary w-100">
                        <i class="bi bi-x-circle me-1"></i>Limpiar
                    </a>
                </div>
            </form>
        </div>
    </div>

    <div class="card">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Fecha</th>
                        <th>Nombre</th>
                        <th>Ubicación</th>
                        <th>Tipo</th>
                        <th>Año</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var feriado in Model)
                    {
                        <tr>
                            <td class="align-middle">@feriado.Fecha.ToString("dd/MM/yyyy")</td>
                            <td class="align-middle">@feriado.Nombre</td>
                            <td class="align-middle">@feriado.UbicacionNombre</td>
                            <td class="align-middle">
                                @if (feriado.EsNacional)
                                {
                                    <span class="badge bg-primary">Nacional</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Local</span>
                                }
                            </td>
                            <td class="align-middle">@feriado.Año</td>
                            <td class="text-end">
                                <a asp-action="Edit" asp-route-id="@feriado.Id"
                                   class="btn btn-sm btn-outline-primary me-1" title="Editar">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <form asp-action="Delete" asp-route-id="@feriado.Id"
                                      method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Eliminar"
                                            onclick="return confirm('¿Está seguro de eliminar el feriado «@feriado.Nombre»?')">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">No hay feriados registrados.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        @if (Model.Any())
        {
            <div class="card-footer text-muted small">
                Total: @Model.Count() feriado(s)
            </div>
        }
    </div>
</div>
