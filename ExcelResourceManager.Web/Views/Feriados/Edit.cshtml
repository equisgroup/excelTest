@model ExcelResourceManager.Core.Models.Feriado

@{
    ViewData["Title"] = "Editar Feriado";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-warning text-dark">
                    <h4 class="mb-0"><i class="bi bi-calendar-event me-2"></i>Editar Feriado</h4>
                </div>
                <div class="card-body">
                    <form asp-action="Edit" method="post">
                        <input type="hidden" asp-for="Id" />
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <div class="mb-3">
                            <label asp-for="UbicacionId" class="form-label">Ubicación</label>
                            <select asp-for="UbicacionId" asp-items="ViewBag.Ubicaciones" class="form-select" required>
                                <option value="">— Seleccione una ubicación —</option>
                            </select>
                            <span asp-validation-for="UbicacionId" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Fecha" class="form-label">Fecha</label>
                            <input asp-for="Fecha" type="date" class="form-control" required />
                            <span asp-validation-for="Fecha" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Nombre" class="form-label">Nombre del Feriado</label>
                            <input asp-for="Nombre" class="form-control" maxlength="200" required />
                            <span asp-validation-for="Nombre" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <div class="form-check">
                                <input asp-for="EsNacional" class="form-check-input" type="checkbox" />
                                <label asp-for="EsNacional" class="form-check-label">Feriado Nacional</label>
                                <div class="form-text">Marque si aplica a todo el país (no solo a la ciudad seleccionada).</div>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="bi bi-arrow-left me-1"></i>Cancelar
                            </a>
                            <button type="submit" class="btn btn-warning">
                                <i class="bi bi-save me-1"></i>Actualizar
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
