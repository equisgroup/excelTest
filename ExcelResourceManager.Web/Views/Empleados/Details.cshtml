@model ExcelResourceManager.Web.Models.EmpleadoDetailsViewModel

@{
    ViewData["Title"] = $"Detalles - {Model.Empleado.NombreCompleto}";
    var empleados = new List<ExcelResourceManager.Core.Models.Empleado> { Model.Empleado };
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-person me-2"></i>@Model.Empleado.NombreCompleto</h2>
        <div>
            <a asp-action="Edit" asp-route-id="@Model.Empleado.Id" class="btn btn-warning me-2">
                <i class="bi bi-pencil me-1"></i>Editar Empleado
            </a>
            <a asp-action="Index" class="btn btn-secondary">
                <i class="bi bi-arrow-left me-1"></i>Volver
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Warning"] != null)
    {
        <div class="alert alert-warning alert-dismissible fade show" role="alert">
            @TempData["Warning"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row mb-4">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="bi bi-person-badge me-2"></i>Información del Empleado</h5>
                </div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-4">Email</dt>
                        <dd class="col-sm-8">@Model.Empleado.Email</dd>
                        <dt class="col-sm-4">Rol Principal</dt>
                        <dd class="col-sm-8"><span class="badge bg-primary">@Model.Empleado.Rol</span></dd>
                        <dt class="col-sm-4">Fecha Ingreso</dt>
                        <dd class="col-sm-8">@Model.Empleado.FechaIngreso.ToString("dd/MM/yyyy")</dd>
                        <dt class="col-sm-4">Estado</dt>
                        <dd class="col-sm-8">
                            @if (Model.Empleado.Activo)
                            {
                                <span class="badge bg-success">Activo</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inactivo</span>
                            }
                        </dd>
                    </dl>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-secondary text-white">
                    <h5 class="mb-0"><i class="bi bi-bar-chart me-2"></i>Resumen</h5>
                </div>
                <div class="card-body">
                    <div class="row text-center">
                        <div class="col-6">
                            <h3 class="text-info">@Model.Vacaciones.Count</h3>
                            <p class="text-muted mb-0">Vacaciones registradas</p>
                        </div>
                        <div class="col-6">
                            <h3 class="text-primary">@Model.Viajes.Count</h3>
                            <p class="text-muted mb-0">Viajes registrados</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Vacaciones -->
    <div class="card mb-4">
        <div class="card-header bg-info text-white">
            <h5 class="mb-0 d-flex justify-content-between align-items-center">
                <span><i class="bi bi-sun me-2"></i>Vacaciones</span>
            </h5>
        </div>
        <div class="card-body">
            <!-- Nueva Solicitud de Vacación -->
            <div class="card mb-3 border-0 bg-light">
                <div class="card-body">
                    <h6 class="card-title">Nueva Solicitud de Vacación</h6>
                    <form asp-controller="Vacaciones" asp-action="Create" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="EmpleadoId" value="@Model.Empleado.Id" />
                        <input type="hidden" name="empleadoId" value="@Model.Empleado.Id" />
                        <div class="row">
                            <div class="col-md-4">
                                <div class="mb-2">
                                    <label class="form-label">Fecha Inicio</label>
                                    <input type="date" name="FechaInicio" class="form-control" required />
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="mb-2">
                                    <label class="form-label">Fecha Fin</label>
                                    <input type="date" name="FechaFin" class="form-control" required />
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="mb-2">
                                    <label class="form-label">&nbsp;</label>
                                    <button type="submit" class="btn btn-info w-100 text-white">
                                        <i class="bi bi-plus-circle me-1"></i>Solicitar
                                    </button>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
            </div>

            @if (!Model.Vacaciones.Any())
            {
                <div class="alert alert-info mb-0">
                    <i class="bi bi-info-circle me-2"></i>No hay vacaciones registradas para este empleado.
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Fecha Inicio</th>
                                <th>Fecha Fin</th>
                                <th>Días</th>
                                <th>Estado</th>
                                <th>Conflictos</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var vacacion in Model.Vacaciones)
                            {
                                <tr>
                                    <td>@vacacion.FechaInicio.ToString("dd/MM/yyyy")</td>
                                    <td>@vacacion.FechaFin.ToString("dd/MM/yyyy")</td>
                                    <td>@vacacion.DiasHabiles</td>
                                    <td>
                                        @switch (vacacion.Estado)
                                        {
                                            case ExcelResourceManager.Core.Enums.EstadoVacacion.Solicitada:
                                                <span class="badge bg-info">Solicitada</span>
                                                break;
                                            case ExcelResourceManager.Core.Enums.EstadoVacacion.Aprobada:
                                                <span class="badge bg-success">Aprobada</span>
                                                break;
                                            case ExcelResourceManager.Core.Enums.EstadoVacacion.Rechazada:
                                                <span class="badge bg-danger">Rechazada</span>
                                                break;
                                            case ExcelResourceManager.Core.Enums.EstadoVacacion.Cancelada:
                                                <span class="badge bg-secondary">Cancelada</span>
                                                break;
                                        }
                                    </td>
                                    <td>
                                        @if (vacacion.TieneConflictos)
                                        {
                                            <span class="badge bg-warning text-dark">Sí</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">No</span>
                                        }
                                    </td>
                                    <td>
                                        @if (vacacion.Estado == ExcelResourceManager.Core.Enums.EstadoVacacion.Solicitada)
                                        {
                                            <form asp-controller="Vacaciones" asp-action="Aprobar" asp-route-id="@vacacion.Id" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="empleadoId" value="@Model.Empleado.Id" />
                                                <button type="submit" class="btn btn-sm btn-success" title="Aprobar">
                                                    <i class="bi bi-check-circle"></i>
                                                </button>
                                            </form>
                                            <form asp-controller="Vacaciones" asp-action="Rechazar" asp-route-id="@vacacion.Id" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="empleadoId" value="@Model.Empleado.Id" />
                                                <button type="submit" class="btn btn-sm btn-warning" title="Rechazar">
                                                    <i class="bi bi-x-circle"></i>
                                                </button>
                                            </form>
                                        }
                                        <form asp-controller="Vacaciones" asp-action="Delete" asp-route-id="@vacacion.Id" method="post" class="d-inline"
                                              onsubmit="return confirm('¿Está seguro que desea eliminar esta vacación?');">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="empleadoId" value="@Model.Empleado.Id" />
                                            <button type="submit" class="btn btn-sm btn-danger" title="Eliminar">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    <!-- Viajes -->
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center bg-primary text-white">
            <h5 class="mb-0"><i class="bi bi-airplane me-2"></i>Viajes</h5>
            <a asp-controller="Viajes" asp-action="Create" asp-route-empleadoId="@Model.Empleado.Id"
               class="btn btn-sm btn-light">
                <i class="bi bi-plus-circle me-1"></i>Nuevo Viaje
            </a>
        </div>
        <div class="card-body">
            @if (!Model.Viajes.Any())
            {
                <div class="alert alert-info mb-0">
                    <i class="bi bi-info-circle me-2"></i>No hay viajes registrados para este empleado.
                    <a asp-controller="Viajes" asp-action="Create" asp-route-empleadoId="@Model.Empleado.Id"
                       class="alert-link">Registrar el primero</a>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Cliente Destino</th>
                                <th>Ubicación</th>
                                <th>Fecha Inicio</th>
                                <th>Fecha Fin</th>
                                <th>Estado</th>
                                <th>Conflictos</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var viaje in Model.Viajes)
                            {
                                <tr>
                                    <td>@viaje.ClienteNombre</td>
                                    <td>@viaje.UbicacionNombre</td>
                                    <td>@viaje.FechaInicio.ToString("dd/MM/yyyy")</td>
                                    <td>@viaje.FechaFin.ToString("dd/MM/yyyy")</td>
                                    <td>
                                        @switch (viaje.Estado)
                                        {
                                            case ExcelResourceManager.Core.Enums.EstadoViaje.Planificado:
                                                <span class="badge bg-primary">Planificado</span>
                                                break;
                                            case ExcelResourceManager.Core.Enums.EstadoViaje.Confirmado:
                                                <span class="badge bg-success">Confirmado</span>
                                                break;
                                            case ExcelResourceManager.Core.Enums.EstadoViaje.EnCurso:
                                                <span class="badge bg-warning text-dark">En Curso</span>
                                                break;
                                            case ExcelResourceManager.Core.Enums.EstadoViaje.Completado:
                                                <span class="badge bg-info text-dark">Completado</span>
                                                break;
                                            case ExcelResourceManager.Core.Enums.EstadoViaje.Cancelado:
                                                <span class="badge bg-secondary">Cancelado</span>
                                                break;
                                        }
                                    </td>
                                    <td>
                                        @if (viaje.TieneConflictos)
                                        {
                                            <span class="badge bg-danger"><i class="bi bi-exclamation-triangle"></i> Sí</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success"><i class="bi bi-check-circle"></i> No</span>
                                        }
                                    </td>
                                    <td>
                                        <a asp-controller="Viajes" asp-action="Edit" asp-route-id="@viaje.Id"
                                           asp-route-empleadoId="@Model.Empleado.Id"
                                           class="btn btn-sm btn-outline-primary" title="Editar">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <form asp-controller="Viajes" asp-action="Delete" asp-route-id="@viaje.Id"
                                              method="post" class="d-inline"
                                              onsubmit="return confirm('¿Está seguro que desea eliminar este viaje?');">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="empleadoId" value="@Model.Empleado.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Eliminar">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>
