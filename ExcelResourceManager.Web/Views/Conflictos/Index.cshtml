@model IEnumerable<ExcelResourceManager.Web.Models.ConflictoViewModel>

@{
    ViewData["Title"] = "Conflictos";
}

<div class="row">
    <div class="col-12">
        <h2>Gestión de Conflictos Futuros</h2>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @if (TempData["Warning"] != null)
        {
            <div class="alert alert-warning alert-dismissible fade show" role="alert">
                @TempData["Warning"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <!-- Información sobre el cálculo -->
        <div class="alert alert-info mb-3">
            <i class="bi bi-info-circle"></i> 
            <strong>Los conflictos se calculan automáticamente al cargar esta página.</strong>
            Solo se muestran conflictos futuros (desde hoy en adelante) para facilitar la planificación.
            <br/>
            <small class="text-muted">Los conflictos se calculan en base a vacaciones, viajes, turnos de soporte y asignaciones de clientes activas.</small>
        </div>

        <div class="card">
            <div class="card-body">
                <h5 class="card-title">
                    <i class="bi bi-exclamation-triangle"></i> Conflictos Detectados: @Model.Count()
                </h5>
                <table class="table table-striped table-hover">
                    <thead>
                        <tr>
                            <th>Tipo</th>
                            <th>Nivel</th>
                            <th>Empleado</th>
                            <th>Email</th>
                            <th>Fecha</th>
                            <th>Descripción</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Any())
                        {
                            @foreach (var conflicto in Model)
                            {
                                <tr>
                                    <td>
                                        @switch (conflicto.Tipo)
                                        {
                                            case ExcelResourceManager.Core.Enums.TipoConflicto.VacacionVsViaje:
                                                <span class="badge bg-danger">Vacación vs Viaje</span>
                                                break;
                                            case ExcelResourceManager.Core.Enums.TipoConflicto.VacacionVsSoporte:
                                                <span class="badge bg-danger">Vacación vs Soporte</span>
                                                break;
                                            case ExcelResourceManager.Core.Enums.TipoConflicto.ViajeVsSoporte:
                                                <span class="badge bg-warning text-dark">Viaje vs Soporte</span>
                                                break;
                                            case ExcelResourceManager.Core.Enums.TipoConflicto.ViajeEnFeriado:
                                                <span class="badge bg-info">Viaje en Feriado</span>
                                                break;
                                            case ExcelResourceManager.Core.Enums.TipoConflicto.VacacionEnFeriado:
                                                <span class="badge bg-info">Vacación en Feriado</span>
                                                break;
                                            case ExcelResourceManager.Core.Enums.TipoConflicto.Sobreasignacion:
                                                <span class="badge bg-warning text-dark">Sobreasignación</span>
                                                break;
                                        }
                                    </td>
                                    <td>
                                        @switch (conflicto.Nivel)
                                        {
                                            case ExcelResourceManager.Core.Enums.NivelConflicto.Critico:
                                                <span class="badge bg-danger">Crítico</span>
                                                break;
                                            case ExcelResourceManager.Core.Enums.NivelConflicto.Alto:
                                                <span class="badge bg-warning text-dark">Alto</span>
                                                break;
                                            case ExcelResourceManager.Core.Enums.NivelConflicto.Medio:
                                                <span class="badge bg-info">Medio</span>
                                                break;
                                            case ExcelResourceManager.Core.Enums.NivelConflicto.Bajo:
                                                <span class="badge bg-secondary">Bajo</span>
                                                break;
                                            case ExcelResourceManager.Core.Enums.NivelConflicto.Informativo:
                                                <span class="badge bg-light text-dark">Informativo</span>
                                                break;
                                        }
                                    </td>
                                    <td>@conflicto.EmpleadoNombre</td>
                                    <td>@conflicto.EmpleadoEmail</td>
                                    <td>@conflicto.FechaConflicto.ToString("dd/MM/yyyy")</td>
                                    <td>
                                        <small>@conflicto.Descripcion</small>
                                        @if (!string.IsNullOrEmpty(conflicto.Recomendacion))
                                        {
                                            <br /><small class="text-muted"><i>@conflicto.Recomendacion</i></small>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted py-4">
                                    <i class="bi bi-check-circle text-success" style="font-size: 2rem;"></i>
                                    <p class="mt-2">No se detectaron conflictos futuros en el sistema</p>
                                    <small>¡Excelente planificación!</small>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
