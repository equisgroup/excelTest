@model ExcelResourceManager.Reports.ImportResult

@{
    ViewData["Title"] = "Resultado de Importación - " + Model.Entidad;
    var erroresJson = System.Text.Json.JsonSerializer.Serialize(Model.Errores);
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2><i class="bi bi-file-earmark-check me-2"></i>Resultado de Importación – @Model.Entidad</h2>
        @if (!string.IsNullOrEmpty(Model.ReturnUrl))
        {
            <a href="@Model.ReturnUrl" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i>Volver a @Model.Entidad
            </a>
        }
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card text-center border-0 shadow-sm">
                <div class="card-body">
                    <div class="display-6 fw-bold text-secondary">@Model.TotalFilas</div>
                    <div class="text-muted small">Filas procesadas</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center border-0 shadow-sm">
                <div class="card-body">
                    <div class="display-6 fw-bold text-success">@Model.Importados</div>
                    <div class="text-muted small">Importados correctamente</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center border-0 shadow-sm">
                <div class="card-body">
                    <div class="display-6 fw-bold text-danger">@Model.Omitidos</div>
                    <div class="text-muted small">Omitidos / con error</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center border-0 shadow-sm">
                <div class="card-body">
                    @{
                        double pct = Model.TotalFilas > 0 ? Math.Round((double)Model.Importados / Model.TotalFilas * 100, 1) : 0;
                    }
                    <div class="display-6 fw-bold @(pct == 100 ? "text-success" : "text-warning")">@pct%</div>
                    <div class="text-muted small">Tasa de éxito</div>
                </div>
            </div>
        </div>
    </div>

    @if (!Model.Errores.Any())
    {
        <div class="alert alert-success">
            <i class="bi bi-check-circle-fill me-2"></i>
            <strong>¡Importación completada sin errores!</strong> Se importaron @Model.Importados registro(s) exitosamente.
        </div>
    }
    else
    {
        <div class="alert alert-warning">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            <strong>Importación completada con @Model.Errores.Count error(es).</strong>
            Se importaron @Model.Importados registro(s) y se omitieron @Model.Omitidos por conflictos o errores de validación.
        </div>

        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="bi bi-exclamation-circle me-2"></i>Ítems Omitidos (@Model.Errores.Count)</h5>
                <form method="post" asp-action="ExportarErrores">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="erroresJson" value="@erroresJson" />
                    <input type="hidden" name="entidad" value="@Model.Entidad" />
                    <button type="submit" class="btn btn-sm btn-outline-success">
                        <i class="bi bi-file-earmark-excel me-1"></i>Exportar errores a Excel
                    </button>
                </form>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive" style="max-height: 450px; overflow-y: auto;">
                    <table class="table table-sm table-hover mb-0">
                        <thead class="table-light sticky-top">
                            <tr>
                                <th style="width:60px">Fila</th>
                                <th>Datos</th>
                                <th>Motivo del Error</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var error in Model.Errores)
                            {
                                <tr>
                                    <td class="text-center align-middle">
                                        <span class="badge bg-secondary">@error.Fila</span>
                                    </td>
                                    <td class="align-middle small text-muted">@error.Datos</td>
                                    <td class="align-middle">
                                        <span class="text-danger"><i class="bi bi-x-circle me-1"></i>@error.Motivo</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>
