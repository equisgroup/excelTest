@model ExcelResourceManager.Core.Models.Ubicacion

@{
    ViewData["Title"] = "Nueva Ubicación";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0"><i class="bi bi-geo-alt-fill me-2"></i>Nueva Ubicación</h4>
                </div>
                <div class="card-body">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <div class="mb-3">
                            <label asp-for="Pais" class="form-label">País</label>
                            <input asp-for="Pais" class="form-control" maxlength="100" required autofocus />
                            <span asp-validation-for="Pais" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Ciudad" class="form-label">Ciudad</label>
                            <input asp-for="Ciudad" class="form-control" maxlength="100" required />
                            <span asp-validation-for="Ciudad" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="CodigoPais" class="form-label">Código País <small class="text-muted">(ISO 3166-1 alpha-2, ej. EC, PY)</small></label>
                            <input asp-for="CodigoPais" class="form-control" maxlength="2" style="text-transform:uppercase" required />
                            <span asp-validation-for="CodigoPais" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ZonaHoraria" class="form-label">Zona Horaria <small class="text-muted">(ej. America/Guayaquil)</small></label>
                            <input asp-for="ZonaHoraria" class="form-control" maxlength="100" required />
                            <span asp-validation-for="ZonaHoraria" class="text-danger"></span>
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="bi bi-arrow-left me-1"></i>Cancelar
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-save me-1"></i>Guardar
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        var codigoPaisInput = document.getElementById('CodigoPais');
        if (codigoPaisInput) {
            codigoPaisInput.addEventListener('input', function () {
                this.value = this.value.toUpperCase();
            });
        }
    </script>
}
