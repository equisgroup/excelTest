@model IEnumerable<ExcelResourceManager.Core.Models.Ubicacion>

@{
    ViewData["Title"] = "Ubicaciones";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2><i class="bi bi-geo-alt me-2"></i>Ubicaciones</h2>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i>Nueva Ubicación
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-circle me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>País</th>
                        <th>Ciudad</th>
                        <th>Código País</th>
                        <th>Zona Horaria</th>
                        <th>Estado</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var ubicacion in Model)
                    {
                        <tr>
                            <td class="align-middle">@ubicacion.Pais</td>
                            <td class="align-middle">@ubicacion.Ciudad</td>
                            <td class="align-middle">
                                <span class="badge bg-info text-dark">@ubicacion.CodigoPais</span>
                            </td>
                            <td class="align-middle"><code>@ubicacion.ZonaHoraria</code></td>
                            <td class="align-middle">
                                @if (ubicacion.Activo)
                                {
                                    <span class="badge bg-success">Activa</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactiva</span>
                                }
                            </td>
                            <td class="text-end">
                                <a asp-action="Edit" asp-route-id="@ubicacion.Id"
                                   class="btn btn-sm btn-outline-primary me-1" title="Editar">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <form asp-action="ToggleActive" asp-route-id="@ubicacion.Id"
                                      method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit"
                                            class="btn btn-sm @(ubicacion.Activo ? "btn-outline-warning" : "btn-outline-success") me-1"
                                            title="@(ubicacion.Activo ? "Desactivar" : "Activar")">
                                        <i class="bi @(ubicacion.Activo ? "bi-toggle-on" : "bi-toggle-off")"></i>
                                    </button>
                                </form>
                                <form asp-action="Delete" asp-route-id="@ubicacion.Id"
                                      method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Eliminar"
                                            onclick="return confirm('¿Está seguro de eliminar la ubicación «@ubicacion.Ciudad»?')">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">No hay ubicaciones registradas.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
