@{
    ViewData["Title"] = "Importar Vacaciones";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2><i class="bi bi-file-earmark-arrow-up me-2"></i>Importar Vacaciones desde Excel</h2>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Volver
        </a>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-circle me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row">
        <div class="col-md-7">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="bi bi-upload me-2"></i>Seleccionar archivo</h5>
                </div>
                <div class="card-body">
                    <form asp-action="ImportarExcel" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        <div class="mb-3">
                            <label class="form-label fw-bold">Archivo Excel (.xlsx)</label>
                            <input type="file" name="archivo" class="form-control" accept=".xlsx,.xls" required />
                            <div class="form-text">Suba el archivo Excel con las vacaciones a importar.</div>
                        </div>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-cloud-upload me-1"></i>Importar
                        </button>
                    </form>
                </div>
            </div>
        </div>
        <div class="col-md-5">
            <div class="card border-info">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0"><i class="bi bi-info-circle me-2"></i>Formato esperado</h5>
                </div>
                <div class="card-body small">
                    <p>El archivo debe tener las siguientes columnas en orden:</p>
                    <table class="table table-sm table-bordered">
                        <thead class="table-light">
                            <tr><th>Col</th><th>Campo</th><th>Requerido</th></tr>
                        </thead>
                        <tbody>
                            <tr><td>A</td><td>Id (ignorado)</td><td>—</td></tr>
                            <tr><td>B</td><td>EmpleadoId</td><td><span class="badge bg-danger">Sí</span></td></tr>
                            <tr><td>C</td><td>Empleado (referencia)</td><td>—</td></tr>
                            <tr><td>D</td><td>FechaInicio (dd/MM/yyyy)</td><td><span class="badge bg-danger">Sí</span></td></tr>
                            <tr><td>E</td><td>FechaFin (dd/MM/yyyy)</td><td><span class="badge bg-danger">Sí</span></td></tr>
                            <tr><td>F</td><td>Estado</td><td>—</td></tr>
                            <tr><td>G</td><td>DiasHabiles</td><td>—</td></tr>
                            <tr><td>H</td><td>TieneConflictos</td><td>—</td></tr>
                            <tr><td>I</td><td>Observaciones</td><td>—</td></tr>
                        </tbody>
                    </table>
                    <p class="mb-1">La primera fila debe contener los encabezados.</p>
                    <p class="mb-0">Estado válido: Solicitada, Aprobada, Rechazada, Cancelada. Los registros con períodos superpuestos para el mismo empleado serán omitidos.</p>
                    <hr />
                    <a asp-action="ExportarExcel" class="btn btn-sm btn-outline-success">
                        <i class="bi bi-file-earmark-excel me-1"></i>Descargar plantilla actual
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
