@model IEnumerable<ExcelResourceManager.Web.Models.VacacionViewModel>

@{
    ViewData["Title"] = "Vacaciones";
    var empleados = ViewBag.Empleados as IEnumerable<ExcelResourceManager.Core.Models.Empleado> ?? Enumerable.Empty<ExcelResourceManager.Core.Models.Empleado>();
}

<style>
    #tablaVacaciones thead th.sortable {
        cursor: pointer;
        user-select: none;
        white-space: nowrap;
    }
    #tablaVacaciones thead th.sortable:hover {
        background-color: rgba(0,0,0,.08);
    }
    #tablaVacaciones thead th .sort-icon {
        margin-left: 4px;
        opacity: 0.4;
        font-size: .8em;
    }
    #tablaVacaciones thead th.asc .sort-icon,
    #tablaVacaciones thead th.desc .sort-icon {
        opacity: 1;
    }
</style>

<div class="row">
    <div class="col-12">
        <h2>Gestión de Vacaciones</h2>
        <div class="d-flex gap-2 mb-3">
            <a asp-action="ExportarExcel" class="btn btn-outline-success">
                <i class="bi bi-file-earmark-excel me-1"></i>Exportar Excel
            </a>
            <a asp-action="ImportarExcel" class="btn btn-outline-primary">
                <i class="bi bi-file-earmark-arrow-up me-1"></i>Importar Excel
            </a>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Warning"] != null)
        {
            <div class="alert alert-warning alert-dismissible fade show" role="alert">
                @TempData["Warning"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <div class="card mb-3">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">Nueva Solicitud de Vacación</h5>
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    <div class="row">
                        <div class="col-md-3">
                            <div class="mb-3">
                                <label class="form-label">Empleado</label>
                                <select name="EmpleadoId" class="form-select" required>
                                    <option value="">Seleccione...</option>
                                    @foreach (var emp in empleados)
                                    {
                                        <option value="@emp.Id">@emp.NombreCompleto</option>
                                    }
                                </select>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="mb-3">
                                <label class="form-label">Fecha Inicio</label>
                                <input type="date" name="FechaInicio" class="form-control" required />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="mb-3">
                                <label class="form-label">Fecha Fin</label>
                                <input type="date" name="FechaFin" class="form-control" required />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="mb-3">
                                <label class="form-label">&nbsp;</label>
                                <button type="submit" class="btn btn-primary w-100">Solicitar</button>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        <div class="card">
            <div class="card-header d-flex align-items-center gap-3">
                <div class="form-check form-switch mb-0">
                    <input class="form-check-input" type="checkbox" id="ocultarVencidas" checked>
                    <label class="form-check-label fw-semibold" for="ocultarVencidas">
                        Ocultar vacaciones vencidas
                    </label>
                </div>
                <small class="text-muted" id="contadorVacaciones"></small>
            </div>
            <div class="card-body">
                <table class="table table-striped table-hover" id="tablaVacaciones">
                    <thead>
                        <tr>
                            <th class="sortable" data-col="0">ID <span class="sort-icon">⇅</span></th>
                            <th class="sortable" data-col="1">Empleado <span class="sort-icon">⇅</span></th>
                            <th class="sortable" data-col="2">Email <span class="sort-icon">⇅</span></th>
                            <th class="sortable" data-col="3">Fecha Inicio <span class="sort-icon">⇅</span></th>
                            <th class="sortable" data-col="4">Fecha Fin <span class="sort-icon">⇅</span></th>
                            <th class="sortable" data-col="5">Días <span class="sort-icon">⇅</span></th>
                            <th class="sortable" data-col="6">Estado <span class="sort-icon">⇅</span></th>
                            <th>Conflictos</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var vacacion in Model)
                        {
                            <tr data-fecha-fin="@vacacion.FechaFin.ToString("yyyy-MM-dd")">
                                <td data-sort="@vacacion.Id">@vacacion.Id</td>
                                <td>@vacacion.EmpleadoNombre</td>
                                <td>@vacacion.EmpleadoEmail</td>
                                <td data-sort="@vacacion.FechaInicio.ToString("yyyy-MM-dd")">@vacacion.FechaInicio.ToString("dd/MM/yyyy")</td>
                                <td data-sort="@vacacion.FechaFin.ToString("yyyy-MM-dd")">@vacacion.FechaFin.ToString("dd/MM/yyyy")</td>
                                <td data-sort="@vacacion.DiasHabiles">@vacacion.DiasHabiles</td>
                                <td>
                                    @switch (vacacion.Estado)
                                    {
                                        case ExcelResourceManager.Core.Enums.EstadoVacacion.Solicitada:
                                            <span class="badge bg-info">Solicitada</span>
                                            break;
                                        case ExcelResourceManager.Core.Enums.EstadoVacacion.Aprobada:
                                            <span class="badge bg-success">Aprobada</span>
                                            break;
                                        case ExcelResourceManager.Core.Enums.EstadoVacacion.Rechazada:
                                            <span class="badge bg-danger">Rechazada</span>
                                            break;
                                        case ExcelResourceManager.Core.Enums.EstadoVacacion.Cancelada:
                                            <span class="badge bg-secondary">Cancelada</span>
                                            break;
                                    }
                                </td>
                                <td>
                                    @if (vacacion.TieneConflictos)
                                    {
                                        <span class="badge bg-warning text-dark">Sí</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">No</span>
                                    }
                                </td>
                                <td>
                                    @if (vacacion.Estado == ExcelResourceManager.Core.Enums.EstadoVacacion.Solicitada)
                                    {
                                        <form asp-action="Aprobar" asp-route-id="@vacacion.Id" method="post" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-success" title="Aprobar">
                                                <i class="bi bi-check-circle"></i>
                                            </button>
                                        </form>
                                        <form asp-action="Rechazar" asp-route-id="@vacacion.Id" method="post" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-warning" title="Rechazar">
                                                <i class="bi bi-x-circle"></i>
                                            </button>
                                        </form>
                                    }
                                    <form asp-action="Delete" asp-route-id="@vacacion.Id" method="post" class="d-inline" onsubmit="return confirm('¿Está seguro que desea eliminar esta vacación?');">
                                        <button type="submit" class="btn btn-sm btn-danger" title="Eliminar">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
(function () {
    const table = document.getElementById('tablaVacaciones');
    const tbody = table.querySelector('tbody');
    const toggle = document.getElementById('ocultarVencidas');
    const counter = document.getElementById('contadorVacaciones');
    const today = new Date().toISOString().slice(0, 10);

    let sortCol = -1;
    let sortDir = 'asc';

    // --- Filter ---
    function applyFilter() {
        const ocultar = toggle.checked;
        let visible = 0;
        Array.from(tbody.rows).forEach(row => {
            const fechaFin = row.dataset.fechaFin;
            const vencida = fechaFin < today;
            const hide = ocultar && vencida;
            row.style.display = hide ? 'none' : '';
            if (!hide) visible++;
        });
        counter.textContent = `Mostrando ${visible} de ${tbody.rows.length} vacaciones`;
    }

    // --- Sort ---
    function sortTable(colIndex) {
        const headers = table.querySelectorAll('thead th.sortable');
        if (sortCol === colIndex) {
            sortDir = sortDir === 'asc' ? 'desc' : 'asc';
        } else {
            sortCol = colIndex;
            sortDir = 'asc';
        }

        headers.forEach(h => {
            h.classList.remove('asc', 'desc');
            h.querySelector('.sort-icon').textContent = '⇅';
        });
        const activeHeader = table.querySelector(`thead th.sortable[data-col="${colIndex}"]`);
        activeHeader.classList.add(sortDir);
        activeHeader.querySelector('.sort-icon').textContent = sortDir === 'asc' ? '↑' : '↓';

        const dateRe = /^\d{4}-\d{2}-\d{2}$/;
        const rows = Array.from(tbody.rows);
        rows.sort((a, b) => {
            const cellA = a.cells[colIndex];
            const cellB = b.cells[colIndex];
            const valA = (cellA.dataset.sort ?? cellA.textContent).trim();
            const valB = (cellB.dataset.sort ?? cellB.textContent).trim();
            let cmp;
            if (dateRe.test(valA) && dateRe.test(valB)) {
                cmp = valA < valB ? -1 : valA > valB ? 1 : 0;
            } else {
                const numA = parseFloat(valA);
                const numB = parseFloat(valB);
                if (!isNaN(numA) && !isNaN(numB)) {
                    cmp = numA - numB;
                } else {
                    cmp = valA.localeCompare(valB, 'es', { sensitivity: 'base' });
                }
            }
            return sortDir === 'asc' ? cmp : -cmp;
        });
        rows.forEach(r => tbody.appendChild(r));
        applyFilter();
    }

    table.querySelectorAll('thead th.sortable').forEach(th => {
        th.addEventListener('click', () => sortTable(parseInt(th.dataset.col)));
    });

    toggle.addEventListener('change', applyFilter);

    // Default: sort by Fecha Inicio ascending (col 3)
    sortTable(3);
})();
</script>
}

